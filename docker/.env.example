ADMIN_PASSWORD=changeme
SECRET_KEY=generate-with-python3-c-import-secrets-print-secrets.token_hex-32
# GID that owns /var/run/docker.sock inside the container.
# Docker Desktop (macOS/Windows): 0 (root group) — the default.
# Linux: run  getent group docker | cut -d: -f3  and set the result here.
DOCKER_GID=0
